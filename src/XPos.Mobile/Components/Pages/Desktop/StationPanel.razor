@page "/d/kitchen"
@page "/desktop/station"
@using Microsoft.AspNetCore.SignalR.Client
@inject HttpClient Http
@inject ISnackbar Snackbar
@inject NavigationManager Nav

<MudContainer MaxWidth="MaxWidth.ExtraLarge" Class="mt-8">
    <div class="header-section mb-8">
        <div class="d-flex align-center gap-4">
            <div class="header-icon">
                <MudIcon Icon="@Icons.Material.Filled.Kitchen" Size="Size.Large" Color="Color.Inherit" />
            </div>
            <div>
                <MudText Typo="Typo.h3" Class="font-bold text-white">İstasyon Paneli</MudText>
                <MudText Typo="Typo.subtitle1" Class="text-muted">Mutfak ve Bar Sipariş Takibi</MudText>
            </div>
        </div>
        <div class="d-flex gap-4 align-center">
            <MudSelect T="int" Value="@currentStationId" ValueChanged="OnStationChanged" 
                       Variant="Variant.Filled" Dense="true" Class="station-select">
                <MudSelectItem Value="1">Mutfak İstasyonu</MudSelectItem>
                <MudSelectItem Value="2">Bar İstasyonu</MudSelectItem>
            </MudSelect>
            <MudFab Color="Color.Primary" StartIcon="@Icons.Material.Filled.Refresh" 
                    OnClick="LoadItems" Size="Size.Small" Class="refresh-fab" />
        </div>
    </div>

    @if (isLoading)
    {
        <div class="loader-container">
            <MudProgressCircular Indeterminate="true" Size="Size.Large" Color="Color.Primary" />
            <MudText Class="mt-4 text-muted">Siparişler alınıyor...</MudText>
        </div>
    }
    else if (!activeItems.Any())
    {
        <div class="empty-state animate-fade-in">
            <div class="empty-icon-wrapper">
                <MudIcon Icon="@Icons.Material.Filled.AssignmentTurnedIn" />
            </div>
            <MudText Typo="Typo.h4" Class="mt-6 font-bold text-white">Her Şey Hazır!</MudText>
            <MudText Class="text-muted">Şu an hazırlık bekleyen sipariş bulunmuyor.</MudText>
        </div>
    }
    else
    {
        <div class="kds-grid animate-fade-in">
            @foreach (var item in activeItems)
            {
                <div class="kds-card @item.StationStatus.ToString().ToLower()">
                    <div class="card-header">
                        <span class="order-id">#@item.OrderId</span>
                        <span class="table-num">@item.TableNumber</span>
                    </div>
                    
                    <div class="card-body">
                        <div class="product-info">
                            <span class="quantity">@item.Quantity x</span>
                            <span class="product-name">@item.ProductName</span>
                        </div>
                        
                        @if (!string.IsNullOrEmpty(item.Note))
                        {
                            <div class="order-note">
                                <MudIcon Icon="@Icons.Material.Filled.StickyNote2" Size="Size.Small" />
                                <span>@item.Note</span>
                            </div>
                        }
                    </div>

                    <div class="card-actions">
                        @if (item.StationStatus == OrderStatus.Pending || item.StationStatus == OrderStatus.Confirmed)
                        {
                            <button class="btn-action start" @onclick="@(() => UpdateStatus(item.Id, OrderStatus.Preparing))">
                                <MudIcon Icon="@Icons.Material.Filled.PlayArrow" Class="mr-2" /> BAŞLA
                            </button>
                        }
                        else if (item.StationStatus == OrderStatus.Preparing)
                        {
                            <button class="btn-action ready" @onclick="@(() => UpdateStatus(item.Id, OrderStatus.Ready))">
                                <MudIcon Icon="@Icons.Material.Filled.CheckCircle" Class="mr-2" /> HAZIR
                            </button>
                        }
                    </div>
                </div>
            }
        </div>
    }
</MudContainer>

<style>
    .header-section { display: flex; justify-content: space-between; align-items: flex-end; }
    .header-icon { 
        width: 56px; height: 56px; background: linear-gradient(135deg, #6366F1, #A855F7); 
        border-radius: 16px; display: flex; align-items: center; justify-content: center; color: white;
        box-shadow: 0 10px 20px rgba(99, 102, 241, 0.3);
    }
    .font-bold { font-weight: 800; letter-spacing: -1px; }
    .text-muted { color: #94A3B8; }
    
    .station-select { min-width: 220px; background: rgba(30, 41, 59, 0.7) !important; color: white !important; border-radius: 12px; }
    .refresh-fab { background: #6366F1 !important; }

    .loader-container { height: 400px; display: flex; flex-direction: column; align-items: center; justify-content: center; }

    .empty-state { height: 500px; display: flex; flex-direction: column; align-items: center; justify-content: center; opacity: 0.8; }
    .empty-icon-wrapper { 
        width: 120px; height: 120px; background: rgba(255,255,255,0.03); border-radius: 50%;
        display: flex; align-items: center; justify-content: center; font-size: 64px; color: #334155;
        border: 2px dashed rgba(255,255,255,0.1);
    }

    .kds-grid { display: grid; grid-template-columns: repeat(auto-fill, minmax(320px, 1fr)); gap: 24px; }
    
    .kds-card {
        background: rgba(30, 41, 59, 0.7); backdrop-filter: blur(16px);
        border: 1px solid rgba(255, 255, 255, 0.08); border-radius: 28px;
        padding: 24px; position: relative; overflow: hidden;
        transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
    }
    .kds-card:hover { transform: translateY(-8px); border-color: rgba(99, 102, 241, 0.4); box-shadow: 0 20px 40px rgba(0,0,0,0.4); }
    .kds-card::before { content: ''; position: absolute; left: 0; top: 0; bottom: 0; width: 6px; background: #6366F1; }
    .kds-card.preparing::before { background: #F59E0B; }
    
    .card-header { display: flex; justify-content: space-between; align-items: center; margin-bottom: 20px; }
    .order-id { font-size: 14px; font-weight: 700; color: #6366F1; background: rgba(99, 102, 241, 0.1); padding: 4px 12px; border-radius: 100px; }
    .table-num { font-size: 20px; font-weight: 800; color: white; }

    .product-info { display: flex; align-items: baseline; gap: 8px; margin-bottom: 12px; }
    .quantity { font-size: 24px; font-weight: 800; color: #818CF8; }
    .product-name { font-size: 22px; font-weight: 700; color: white; line-height: 1.2; }

    .order-note { 
        background: rgba(245, 158, 11, 0.1); color: #F59E0B; padding: 12px 16px; border-radius: 16px;
        display: flex; align-items: flex-start; gap: 10px; font-size: 14px; margin-top: 16px;
    }

    .card-actions { margin-top: 24px; }
    .btn-action { 
        width: 100%; height: 56px; border-radius: 18px; border: none; font-weight: 700; font-size: 16px;
        display: flex; align-items: center; justify-content: center; transition: all 0.2s;
    }
    .btn-action.start { background: #F59E0B; color: #1E293B; }
    .btn-action.ready { background: #10B981; color: white; }
    .btn-action:active { transform: scale(0.96); }

    .animate-fade-in { animation: fadeIn 0.5s ease-out; }
    @@keyframes fadeIn { from { opacity: 0; transform: translateY(20px); } to { opacity: 1; transform: translateY(0); } }
</style>

@code {
    private List<OrderItemDto> activeItems = new();
    private bool isLoading = true;
    private int currentStationId = 1; // Default Kitchen
    private HubConnection? hubConnection;

    protected override async Task OnInitializedAsync()
    {
        await LoadItems();
        await StartSignalR();
    }

    private async Task OnStationChanged(int stationId)
    {
        currentStationId = stationId;
        await LoadItems();
    }

    private async Task LoadItems()
    {
        isLoading = true;
        try
        {
            activeItems = await Http.GetFromJsonAsync<List<OrderItemDto>>($"api/station/{currentStationId}/active-items") ?? new();
        }
        catch (Exception ex)
        {
            Snackbar.Add("Siparişler yüklenemedi: " + ex.Message, Severity.Error);
        }
        finally
        {
            isLoading = false;
        }
    }

    private async Task UpdateStatus(int itemId, OrderStatus status)
    {
        try
        {
            var response = await Http.PutAsJsonAsync($"api/orders/item/{itemId}/status", (int)status);
            if (response.IsSuccessStatusCode)
            {
                Snackbar.Add("Durum güncellendi", Severity.Success);
                await LoadItems();
            }
            else
            {
                Snackbar.Add("Hata oluştu", Severity.Error);
            }
        }
        catch (Exception ex)
        {
            Snackbar.Add("İşlem başarısız: " + ex.Message, Severity.Error);
        }
    }

    private async Task StartSignalR()
    {
        var baseUri = Http.BaseAddress?.ToString() ?? "http://localhost:5029/";
        hubConnection = new HubConnectionBuilder()
            .WithUrl(baseUri + "orderhub")
            .WithAutomaticReconnect()
            .Build();

        hubConnection.On<OrderDto>("OrderReceived", (order) =>
        {
            InvokeAsync(async () =>
            {
                // Yeni sipariş geldiğinde eğer bizim istasyona ait ürün varsa listeyi yenile
                await LoadItems();
                StateHasChanged();
            });
        });

        try { await hubConnection.StartAsync(); }
        catch (Exception ex) { Console.WriteLine($"SignalR Error: {ex.Message}"); }
    }

    public void Dispose()
    {
        _ = hubConnection?.DisposeAsync();
    }
}
