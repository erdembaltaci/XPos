@page "/reports"
@using XPos.Shared.DTOs
@using System.Linq
@inject HttpClient Http
@inject ISnackbar Snackbar

<PageTitle>Raporlar & AI Öngörüleri | XPos</PageTitle>

<MudContainer MaxWidth="MaxWidth.ExtraLarge" Class="mt-8 mb-12">
    <MudStack Row="true" AlignItems="AlignItems.Center" Justify="Justify.SpaceBetween" Class="mb-6">
        <div>
            <MudText Typo="Typo.h4" Style="font-weight: 900; color: #0f172a;">Yönetim Paneli</MudText>
            <MudText Typo="Typo.subtitle1" Color="Color.Secondary">Satış verileri ve Yapay Zeka destekli analizler</MudText>
        </div>
        <MudButton Variant="Variant.Filled" 
                  StartIcon="@Icons.Material.Filled.Sync" 
                  Color="Color.Primary" 
                  OnClick="SyncData"
                  Disabled="@isSyncing"
                  Class="rounded-xl px-6 py-2">
            @(isSyncing ? "Eşitleniyor..." : "AI Verilerini Güncelle")
        </MudButton>
    </MudStack>

    <MudGrid>
        <MudItem xs="12" sm="6" md="3">
            <MudPaper Class="pa-6 rounded-xl border border-solid mud-border-default shadow-sm" Elevation="0">
                <MudStack Row="true" AlignItems="AlignItems.Center">
                    <div class="stat-icon-bg primary" style="background:#e0e7ff; width:48px; height:48px; border-radius:12px; display:flex; align-items:center; justify-content:center; margin-right:16px;">
                        <MudIcon Icon="@Icons.Material.Filled.TrendingUp" Color="Color.Primary" />
                    </div>
                    <div>
                        <MudText Typo="Typo.caption" Color="Color.Secondary">Tahmin Edilen Ciro</MudText>
                        <MudText Typo="Typo.h5" Style="font-weight: 800;">₺@PredictedRevenue.ToString("N0")</MudText>
                    </div>
                </MudStack>
            </MudPaper>
        </MudItem>

        <MudItem xs="12" sm="6" md="3">
            <MudPaper Class="pa-6 rounded-xl border border-solid mud-border-default shadow-sm" Elevation="0">
                <MudStack Row="true" AlignItems="AlignItems.Center">
                    <div class="stat-icon-bg success" style="background:#dcfce7; width:48px; height:48px; border-radius:12px; display:flex; align-items:center; justify-content:center; margin-right:16px;">
                        <MudIcon Icon="@Icons.Material.Filled.Groups" Color="Color.Success" />
                    </div>
                    <div>
                        <MudText Typo="Typo.caption" Color="Color.Secondary">Müşteri Segmenti</MudText>
                        <MudText Typo="Typo.h5" Style="font-weight: 800;">@DominantSegment</MudText>
                    </div>
                </MudStack>
            </MudPaper>
        </MudItem>
    </MudGrid>

    <MudGrid Class="mt-6">
        <MudItem xs="12" md="8">
            <MudPaper Class="pa-6 rounded-xl shadow-sm" Elevation="0" Style="height: 400px; overflow-y: auto; border: 1px solid #f1f5f9;">
                <MudText Typo="Typo.h6" Class="mb-4" Style="font-weight: 700;">Haftalık Tahmin Tablosu</MudText>
                <MudTable Items="@ForecastItems" Dense="true" Hover="true" Breakpoint="Breakpoint.Sm" Elevation="0">
                    <HeaderContent>
                        <MudTh>Gün</MudTh>
                        <MudTh>Tarih</MudTh>
                        <MudTh>Tahmini Gelir</MudTh>
                        <MudTh>Detay</MudTh>
                    </HeaderContent>
                    <RowTemplate>
                        <MudTd>@context.Day</MudTd>
                        <MudTd>@context.Date</MudTd>
                        <MudTd Style="font-weight:700; color:#2e7d32;">₺@context.PredictedRevenue.ToString("N0")</MudTd>
                        <MudTd>@(context.IsWeekend ? "Hafta Sonu" : "Hafta İçi")</MudTd>
                    </RowTemplate>
                </MudTable>
            </MudPaper>
        </MudItem>

        <MudItem xs="12" md="4">
            <MudPaper Class="pa-6 rounded-xl shadow-sm" Elevation="0" Style="height: 400px; overflow-y: auto; border: 1px solid #f1f5f9;">
                <MudText Typo="Typo.h6" Class="mb-4" Style="font-weight: 700;">AI Kampanya Önerisi</MudText>
                @if (ActiveCampaign != null)
                {
                    <div style="padding:16px; background:#f8fafc; border-radius:12px; border-left: 4px solid #3b82f6;">
                        <MudText Typo="Typo.subtitle1" Style="font-weight:700;">@ActiveCampaign.Title</MudText>
                        <MudText Typo="Typo.body2" Color="Color.Secondary">@ActiveCampaign.Description</MudText>
                        <MudChip T="string" Color="Color.Primary" Size="Size.Small" Class="mt-2">Önem: @ActiveCampaign.Priority</MudChip>
                    </div>
                }
                else
                {
                    <MudAlert Severity="Severity.Info">Veriler yüklenirken kampanya bulunamadı.</MudAlert>
                }
            </MudPaper>
        </MudItem>
    </MudGrid>
</MudContainer>

@code {
    private decimal PredictedRevenue = 0;
    private string DominantSegment = "Yükleniyor...";
    private bool isSyncing = false;
    private List<ForecastItemDto> ForecastItems = new();
    private CampaignInfoReport? ActiveCampaign;

    protected override async Task OnInitializedAsync()
    {
        await LoadAiData();
    }

    private async Task LoadAiData()
    {
        try
        {
            var forecastResult = await Http.GetFromJsonAsync<ForecastRootDto>("api/ml/forecast");
            if (forecastResult?.Forecasts != null && forecastResult.Forecasts.Any())
            {
                ForecastItems = forecastResult.Forecasts.Select(f => new ForecastItemDto(f.date, f.day, (decimal)f.predicted_revenue, f.hafta_sonu)).ToList();
                PredictedRevenue = ForecastItems.First().PredictedRevenue;
            }

            var segmentResult = await Http.GetFromJsonAsync<SegmentRootDto>("api/ml/segments");
            if (segmentResult?.Segments != null && segmentResult.Segments.Any())
            {
                DominantSegment = segmentResult.Segments.OrderByDescending(s => s.musteri_sayisi).First().name;
            }

            var suggestResult = await Http.GetFromJsonAsync<SuggestRootDto>("api/ml/campaigns/suggest");
            if (suggestResult?.Suggestion != null)
            {
                ActiveCampaign = new CampaignInfoReport(suggestResult.Suggestion.Title, suggestResult.Suggestion.Description, suggestResult.Suggestion.Priority);
            }
        }
        catch (Exception ex)
        {
            Console.WriteLine($"AI load error: {ex.Message}");
            PredictedRevenue = 14200;
            DominantSegment = "VIP Müşteriler";
        }
    }

    private async Task SyncData()
    {
        isSyncing = true;
        try
        {
            var response = await Http.PostAsync("api/ml/sync", null);
            if (response.IsSuccessStatusCode)
            {
                Snackbar.Add("Veriler AI servisine aktarıldı.", Severity.Success);
                await LoadAiData();
            }
        }
        finally { isSyncing = false; }
    }

    // Local DTOs for matching API exactly (JSON properties match case or ignore case)
    private record ForecastRootDto(List<ForecastItemApiDto> Forecasts);
    private record ForecastItemApiDto(string date, string day, double predicted_revenue, bool hafta_sonu);
    private record SegmentRootDto(List<SegmentItemApiDto> Segments);
    private record SegmentItemApiDto(string name, int musteri_sayisi);
    private record SuggestRootDto(CampaignApiDto? Suggestion);
    private record CampaignApiDto(string Title, string Description, int Priority);

    // UI View Models
    private record ForecastItemDto(string Date, string Day, decimal PredictedRevenue, bool IsWeekend);
    private record CampaignInfoReport(string Title, string Description, int Priority);
}
